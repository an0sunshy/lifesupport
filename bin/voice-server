#!/usr/bin/env python3
"""Voice-to-text server using parakeet-mlx (macOS Apple Silicon only).

Listens on a unix socket. Commands: start, stop, ping.
"""

import json
import os
import platform
import signal
import socket
import sys
import tempfile
import threading
import time

if platform.system() != "Darwin":
    sys.exit("voice-server: macOS only. Linux/WSL support not yet implemented.")

SOCK_PATH = os.path.expanduser("~/.cache/voice-server.sock")
MODEL_RATE = 16000
HEALTH_CHECK_INTERVAL = 60  # seconds

_recording = False
_audio_frames = []
_lock = threading.Lock()
_device_rate = None
_model = None


def _log(msg):
    print(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] {msg}", flush=True)


def _load_model():
    global _model
    from parakeet_mlx import from_pretrained
    t0 = time.time()
    _model = from_pretrained("mlx-community/parakeet-tdt-0.6b-v3")
    _log(f"model loaded in {time.time() - t0:.1f}s")


def _record_callback(indata, frames, time_info, status):
    if _recording:
        _audio_frames.append(indata.copy())


def _resample(audio, orig_rate, target_rate):
    import numpy as np
    if orig_rate == target_rate:
        return audio
    ratio = target_rate / orig_rate
    n_out = int(len(audio) * ratio)
    indices = np.arange(n_out) / ratio
    floor = np.floor(indices).astype(int)
    ceil = np.minimum(floor + 1, len(audio) - 1)
    frac = indices - floor
    return audio[floor] * (1 - frac) + audio[ceil] * frac


def _start_recording():
    global _recording, _audio_frames, _device_rate
    import sounddevice as sd
    with _lock:
        _audio_frames = []
        _recording = True
    dev_info = sd.query_devices(kind="input")
    _device_rate = int(dev_info["default_samplerate"])
    _start_recording._stream = sd.InputStream(
        samplerate=_device_rate, channels=1, dtype="float32",
        callback=_record_callback,
    )
    _start_recording._stream.start()
    _log("recording started")


def _stop_and_transcribe():
    global _recording
    import numpy as np
    import soundfile as sf
    with _lock:
        _recording = False
    _start_recording._stream.stop()
    _start_recording._stream.close()
    if not _audio_frames:
        _log("no audio frames captured")
        return ""
    audio = np.concatenate(_audio_frames, axis=0).flatten()
    duration = len(audio) / _device_rate
    _log(f"recorded {duration:.1f}s audio, resampling...")
    audio = _resample(audio, _device_rate, MODEL_RATE)
    fd, tmp = tempfile.mkstemp(suffix=".wav")
    os.close(fd)
    try:
        sf.write(tmp, audio, MODEL_RATE)
        t0 = time.time()
        text = _model.transcribe(tmp).text
        _log(f"transcribed in {time.time() - t0:.1f}s: {len(text)} chars")
        return text
    finally:
        os.unlink(tmp)


def _handle(conn):
    try:
        cmd = conn.recv(64).decode().strip()
        _log(f"cmd: {cmd}")
        if cmd == "start":
            _start_recording()
            try:
                conn.sendall(b"ok\n")
            except OSError:
                pass
        elif cmd == "stop":
            text = _stop_and_transcribe()
            conn.sendall(json.dumps({"text": text}).encode() + b"\n")
        elif cmd == "ping":
            conn.sendall(b"pong\n")
    except Exception as e:
        _log(f"error handling '{cmd if 'cmd' in dir() else '?'}': {e}")
        try:
            conn.sendall(json.dumps({"error": str(e)}).encode() + b"\n")
        except OSError:
            pass
    finally:
        conn.close()


def _audio_health_check(srv):
    """Periodically verify audio subsystem is functional."""
    while True:
        time.sleep(HEALTH_CHECK_INTERVAL)
        try:
            import sounddevice as sd
            sd.query_devices(kind="input")
        except Exception as e:
            _log(f"audio health check failed: {e} — exiting for restart")
            srv.close()
            if os.path.exists(SOCK_PATH):
                os.unlink(SOCK_PATH)
            os._exit(1)


def main():
    # Load model BEFORE accepting connections — no race condition
    _log("loading model...")
    try:
        _load_model()
    except Exception as e:
        _log(f"FATAL: model load failed: {e}")
        sys.exit(1)

    if os.path.exists(SOCK_PATH):
        os.unlink(SOCK_PATH)
    os.makedirs(os.path.dirname(SOCK_PATH), exist_ok=True)

    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(SOCK_PATH)
    srv.listen(1)
    _log(f"listening on {SOCK_PATH}")

    # Start audio health check thread
    threading.Thread(target=_audio_health_check, args=(srv,), daemon=True).start()

    def _shutdown(sig, frame):
        _log(f"shutting down (signal {sig})")
        srv.close()
        if os.path.exists(SOCK_PATH):
            os.unlink(SOCK_PATH)
        sys.exit(0)

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT, _shutdown)

    while True:
        try:
            conn, _ = srv.accept()
            threading.Thread(target=_handle, args=(conn,), daemon=True).start()
        except OSError:
            break  # socket closed by shutdown or health check


if __name__ == "__main__":
    main()
