#!/usr/bin/env python3
"""Voice-to-text server using parakeet-mlx (macOS Apple Silicon only).

Listens on a unix socket. Commands: start, stop, ping.

Note: MLX GPU operations have thread affinity — transcription must run on
the main thread. Socket handlers run in threads but dispatch transcription
work to the main thread via a queue.
"""

import os
import sys

# Re-exec under venv python if running from system python
_VENV_PYTHON = os.path.expanduser("~/.local/share/voice-server/venv/bin/python3")
if os.path.exists(_VENV_PYTHON) and os.path.realpath(sys.executable) != os.path.realpath(_VENV_PYTHON):
    try:
        os.execv(_VENV_PYTHON, [_VENV_PYTHON] + sys.argv)
    except OSError as e:
        print(f"[voice-server] FATAL: venv re-exec failed: {e}", file=sys.stderr)
        sys.exit(1)

import json
import os
import platform
import queue
import shutil
import signal
import socket
import sys
import tempfile
import threading
import time

if platform.system() != "Darwin":
    sys.exit("voice-server: macOS only. Linux/WSL support not yet implemented.")

import numpy as np

SOCK_PATH = os.path.expanduser("~/.cache/voice-server.sock")
LAST_WAV_DIR = os.path.expanduser("~/.cache/voice-server")
LAST_WAV = os.path.join(LAST_WAV_DIR, "last-recording.wav")
STARTED_FILE = os.path.expanduser("~/.cache/voice-server.started")
MODEL_RATE = 16000
HEALTH_CHECK_INTERVAL = 60  # seconds

_recording = False
_audio_frames = []
_stream = None
_lock = threading.Lock()
_peak_level = 0.0
_device_rate = None
_model = None

# Queue for dispatching transcription to main thread
_transcribe_queue = queue.Queue()


def _log(msg):
    print(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] {msg}", flush=True)


def _load_model():
    global _model
    # Use cached model if available — avoids HF Hub network calls on every restart
    os.environ.setdefault("HF_HUB_OFFLINE", "1")
    from parakeet_mlx import from_pretrained
    t0 = time.time()
    try:
        _model = from_pretrained("mlx-community/parakeet-tdt-0.6b-v3")
    except Exception as e:
        # Cache miss — fall back to online download
        _log(f"offline model load failed ({e}), trying online...")
        os.environ.pop("HF_HUB_OFFLINE", None)
        _model = from_pretrained("mlx-community/parakeet-tdt-0.6b-v3")
    _log(f"model loaded in {time.time() - t0:.1f}s")


def _record_callback(indata, frames, time_info, status):
    global _peak_level
    if _recording:
        _audio_frames.append(indata.copy())
        # Track peak amplitude for level indicator
        peak = float(np.max(np.abs(indata)))
        _peak_level = max(_peak_level, peak)


def _resample(audio, orig_rate, target_rate):
    import numpy as np
    if orig_rate == target_rate:
        return audio
    from scipy.signal import resample_poly
    from math import gcd
    g = gcd(int(target_rate), int(orig_rate))
    return resample_poly(audio, int(target_rate) // g, int(orig_rate) // g).astype(np.float32)


def _start_recording():
    global _recording, _audio_frames, _device_rate, _stream
    import sounddevice as sd
    with _lock:
        if _stream is not None:
            try:
                _stream.close()
            except Exception:
                pass
        _audio_frames = []
        _recording = True
        dev_info = sd.query_devices(kind="input")
        _device_rate = int(dev_info["default_samplerate"])
        _stream = sd.InputStream(
            samplerate=_device_rate, channels=1, dtype="float32",
            callback=_record_callback,
        )
        _stream.start()
    with open(STARTED_FILE, "w") as f:
        f.write(str(time.time()))
    _log("recording started")


def _stop_and_transcribe():
    """Stop recording and transcribe. Must run on main thread (MLX requirement)."""
    global _recording, _stream
    import numpy as np
    import soundfile as sf
    with _lock:
        _recording = False
        frames = list(_audio_frames)
    if os.path.exists(STARTED_FILE):
        os.unlink(STARTED_FILE)
    if _stream is None:
        _log("stop called with no active stream — ignoring")
        return ""
    try:
        _stream.close()
    except Exception:
        pass
    _stream = None
    if not frames:
        _log("no audio frames captured")
        return ""
    audio = np.concatenate(frames, axis=0).flatten()
    duration = len(audio) / _device_rate
    _log(f"recorded {duration:.1f}s audio, resampling...")
    audio = _resample(audio, _device_rate, MODEL_RATE)
    fd, tmp = tempfile.mkstemp(suffix=".wav")
    os.close(fd)
    try:
        sf.write(tmp, audio, MODEL_RATE)
        # Save a copy before transcription so retry can re-transcribe
        os.makedirs(LAST_WAV_DIR, exist_ok=True)
        shutil.copy2(tmp, LAST_WAV)
        _log(f"saved last recording to {LAST_WAV}")
        t0 = time.time()
        text = _model.transcribe(tmp).text
        _log(f"transcribed in {time.time() - t0:.1f}s: {len(text)} chars")
        return text
    finally:
        os.unlink(tmp)


def _retry_transcribe():
    """Re-transcribe the last saved recording. Must run on main thread (MLX requirement)."""
    if not os.path.exists(LAST_WAV):
        return None
    t0 = time.time()
    text = _model.transcribe(LAST_WAV).text
    _log(f"retry transcribed in {time.time() - t0:.1f}s: {len(text)} chars")
    return text


def _handle(conn):
    try:
        cmd = conn.recv(64).decode().strip()
        _log(f"cmd: {cmd}")
        if cmd == "start":
            _start_recording()
            try:
                conn.sendall(b"ok\n")
            except OSError:
                pass
        elif cmd == "stop":
            # Dispatch to main thread — MLX requires it
            result_q = queue.Queue()
            _transcribe_queue.put((result_q, "stop"))
            try:
                text = result_q.get(timeout=60)
            except queue.Empty:
                _log("transcription timed out after 60s")
                conn.sendall(json.dumps({"error": "timeout"}).encode() + b"\n")
                return
            conn.sendall(json.dumps({"text": text}).encode() + b"\n")
        elif cmd == "ping":
            conn.sendall(b"pong\n")
        elif cmd == "level":
            global _peak_level
            with _lock:
                peak = _peak_level
                recording = _recording
                _peak_level = 0.0
            conn.sendall(json.dumps({"recording": recording, "peak": round(peak, 3)}).encode() + b"\n")
        elif cmd == "retry":
            # Dispatch retry to main thread — MLX requires it
            result_q = queue.Queue()
            _transcribe_queue.put((result_q, "retry"))
            try:
                text = result_q.get(timeout=60)
            except queue.Empty:
                _log("retry transcription timed out after 60s")
                conn.sendall(json.dumps({"error": "timeout"}).encode() + b"\n")
                return
            if text is None:
                conn.sendall(json.dumps({"error": "no saved recording"}).encode() + b"\n")
            else:
                conn.sendall(json.dumps({"text": text}).encode() + b"\n")
    except Exception as e:
        _log(f"error handling '{cmd if 'cmd' in dir() else '?'}': {e}")
        try:
            conn.sendall(json.dumps({"error": str(e)}).encode() + b"\n")
        except OSError:
            pass
    finally:
        conn.close()


def _audio_health_check(srv):
    """Periodically verify audio subsystem is functional."""
    while True:
        time.sleep(HEALTH_CHECK_INTERVAL)
        try:
            import sounddevice as sd
            sd.query_devices(kind="input")
        except Exception as e:
            _log(f"audio health check failed: {e} — exiting for restart")
            srv.close()
            if os.path.exists(SOCK_PATH):
                os.unlink(SOCK_PATH)
            os._exit(1)


def main():
    # Load model BEFORE accepting connections — no race condition
    _log("loading model...")
    try:
        _load_model()
    except Exception as e:
        _log(f"FATAL: model load failed: {e}")
        sys.exit(1)

    if os.path.exists(SOCK_PATH):
        os.unlink(SOCK_PATH)
    os.makedirs(os.path.dirname(SOCK_PATH), exist_ok=True)

    srv = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    srv.bind(SOCK_PATH)
    srv.listen(1)
    _log(f"listening on {SOCK_PATH}")

    # Start audio health check thread
    threading.Thread(target=_audio_health_check, args=(srv,), daemon=True).start()

    def _shutdown(sig, frame):
        _log(f"shutting down (signal {sig})")
        srv.close()
        if os.path.exists(SOCK_PATH):
            os.unlink(SOCK_PATH)
        sys.exit(0)

    signal.signal(signal.SIGTERM, _shutdown)
    signal.signal(signal.SIGINT, _shutdown)

    # Accept connections in a thread so main thread can process transcriptions
    def _accept_loop():
        while True:
            try:
                conn, _ = srv.accept()
                threading.Thread(target=_handle, args=(conn,), daemon=True).start()
            except OSError:
                break

    threading.Thread(target=_accept_loop, daemon=True).start()

    # Main thread: process transcription requests (MLX GPU thread affinity)
    while True:
        try:
            result_q, action = _transcribe_queue.get(timeout=1)
        except queue.Empty:
            continue
        try:
            if action == "retry":
                text = _retry_transcribe()
            else:
                text = _stop_and_transcribe()
            result_q.put(text)
        except Exception as e:
            _log(f"transcription error: {e}")
            result_q.put("")


if __name__ == "__main__":
    main()
