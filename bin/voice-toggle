#!/usr/bin/env bash
# ~/dev/lifesupport/bin/voice-toggle
# Usage: voice-toggle <pane_id> | --toggle-mode

exec 2>>"${HOME}/.cache/voice-toggle.log"

SOCK="${HOME}/.cache/voice-server.sock"
STATE="${HOME}/.cache/voice-server.state"
PROC="${HOME}/.cache/voice-server.processing"
DONE="${HOME}/.cache/voice-server.done"
PANE_FILE="${HOME}/.cache/voice-server.pane"
MODE_FILE="${HOME}/.cache/voice-server.mode"
PANE_ID="${1:-}"

# Shift+F9: toggle mode
if [[ "$PANE_ID" == "--toggle-mode" ]]; then
  if [[ -f "$MODE_FILE" ]]; then
    rm -f "$MODE_FILE"
    tmux display-message "🎤 Voice: ✏️ review"
  else
    touch "$MODE_FILE"
    tmux display-message "🎤 Voice: 🚀 auto"
  fi
  exit 0
fi

if [[ ! -S "$SOCK" ]]; then
  tmux display-message "voice-server not running"
  exit 1
fi

if [[ -f "$STATE" ]]; then
  # Stop recording → processing → transcribe → done
  rm -f "$STATE"
  touch "$PROC"
  target=$(cat "$PANE_FILE")
  tmux display-message "⏳ Transcribing..."

  text=$(echo "stop" | socat -t 30 - UNIX-CONNECT:"$SOCK" \
    | python3 -c "
import sys, json, re
raw = json.load(sys.stdin).get('text', '')
fillers = r'\b(um|uh|uh huh|uhh|umm|hmm|hm|er|ah|like,?|you know,?|I mean,?|so,?|well,?|basically,?|actually,?|right,?|okay so,?)\b'
text = re.sub(fillers, '', raw, flags=re.IGNORECASE)
text = re.sub(r'\s{2,}', ' ', text)
text = re.sub(r'\s+([.,!?])', r'\1', text)
text = re.sub(r'^[,.\s]+', '', text)
text = text.strip()
if text:
    text = text[0].upper() + text[1:]
print(text, end='')
")

  rm -f "$PROC"

  if [[ -n "$text" ]]; then
    printf '%s' "$text" | pbcopy
    tmux send-keys -t "$target" -l "$text"
    [[ -f "$MODE_FILE" ]] && tmux send-keys -t "$target" Enter
    echo "✅" > "$DONE"
    tmux display-message "✅ Sent ${#text} chars"
  else
    echo "⚠️" > "$DONE"
    tmux display-message "⚠️ No speech detected"
  fi
  rm -f "$PANE_FILE"
  # Auto-clear done badge after 3s
  (sleep 3 && rm -f "$DONE") &
  disown
else
  # Start recording
  if echo "start" | socat -t 5 - UNIX-CONNECT:"$SOCK" >/dev/null 2>&1; then
    echo "$PANE_ID" > "$PANE_FILE"
    touch "$STATE"
    tmux display-message "⏺️ Recording..."
  else
    tmux display-message "❌ voice-server not responding — run: voice-restart"
  fi
fi
